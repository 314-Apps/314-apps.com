# Stock Advisor Configuration
# Copy this to .env and customize

# Optional API keys (app works without them using free data sources)
SA_NEWSAPI_KEY=
SA_ALPHA_VANTAGE_KEY=
SA_FINNHUB_KEY=

# Portfolio settings
SA_DEFAULT_PORTFOLIO_VALUE=100000.0
SA_MAX_POSITION_PCT=0.10
SA_MAX_TOTAL_EXPOSURE_PCT=0.80
SA_STOP_LOSS_PCT=0.07
SA_TAKE_PROFIT_PCT=0.15
SA_MIN_SIGNAL_CONFIDENCE=0.60

# Analysis weights (must sum to 1.0)
SA_SENTIMENT_WEIGHT=0.35
SA_TECHNICAL_WEIGHT=0.45
SA_FUNDAMENTAL_WEIGHT=0.20

# Debug mode
SA_DEBUG=false

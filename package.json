{
  "name": "314-apps-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "start": "node --import tsx server/src/index.ts",
    "ddb:create-table": "tsx server/scripts/create-table.ts",
    "fish:dev": "bash scripts/fish-dev-up.sh",
    "start:mock": "env USE_MOCK_LEADERBOARD=1 PAYOUT_PLACES_HEURISTIC=45 node --import tsx server/src/index.ts",
    "dev:mock": "env USE_MOCK_LEADERBOARD=1 PAYOUT_PLACES_HEURISTIC=45 tsx watch server/src/index.ts",
    "fish:mock": "bash scripts/fish-mock-dev.sh",
    "train:historical": "tsx server/scripts/train-historical.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

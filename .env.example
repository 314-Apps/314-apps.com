# Use 8080 if you prefer http://localhost:8080/fish/ (same server serves API + static).
PORT=3000

# One-command setup + smoke test + dev server (default port 8787; override with FISH_DEV_PORT):
#   npm run fish:dev
#   FISH_DEV_PORT=8080 npm run fish:dev
AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000
TABLE_NAME=bbb_fish_leaderboard
CACHE_TTL_SECONDS=300

# Server-side: fetch A Leaderboard on a timer (no browser required). Defaults to CACHE_TTL_SECONDS.
# AUTO_SCRAPE_INTERVAL_MS=300000
# Set to false to rely only on HTTP traffic (e.g. /fish) to trigger scrapes.
# AUTO_SCRAPE_ENABLED=true

# Main A Leaderboard widget (Big Bass Bash). UUID may change per event.
ALEADERBOARD_WIDGET_URL=https://aleaderboard.com/w2/a1161cea-9cb6-4179-9b33-f8baef855ee1

# Optional: fetch Midwest page and pick tallest iframe src if widget URL is empty
MIDWEST_LIVE_PAGE_URL=https://midwestfishtournaments.com/live-leaderboard/

# Heuristic: compare fish to Nth place in current period (Big Bass Bash pays top 45 per period)
PAYOUT_PLACES_HEURISTIC=45

# Minimum modeled pay % to show “consider weighing in” floor (default 10). Same model as payout %.
# PAYOUT_CONSIDER_FLOOR_PERCENT=10

# Widen σ only for pay-chance Φ(z) (default 1.28). Tune with npm run evaluate:predictions ECE.
# PAYOUT_LIKELIHOOD_SIGMA_MULT=1.28
# Early-window pay CDF widening for shadow algo `normalBlendElapsedWide` (σ_pay *= 1 + K*(1−f)²). Default 0.6.
# PAYOUT_EARLY_SIGMA_WIDEN_K=0.6

# Live scrape defaults (also controllable via POST /api/settings and /fish Advanced toggles)
# DEFAULT_LIVE_SCRAPE_ENABLED=true
# When false, API serves last DynamoDB snapshot only until you enable scraping.
# npm run fish:dev forces default true unless you set this to false in .env.
# DEFAULT_TRAINING_CAPTURE=true
# Append JSONL on each live scrape (0 = no throttle; set e.g. 30000 to limit writes per window)
# TRAINING_CAPTURE_MIN_INTERVAL_MS=0

# Optional: npm run sweep:predictions — grid-calls /api/recommendation every minute (second terminal)
# Default port is 8787 (same as npm run fish:dev). If you use npm run dev on 3000, set:
# PREDICTION_SWEEP_PORT=3000
# PREDICTION_SWEEP_API_BASE=http://127.0.0.1:8787
# PREDICTION_SWEEP_INTERVAL_MS=60000
# PREDICTION_SWEEP_MIN_LB=2
# PREDICTION_SWEEP_MAX_LB=6
# PREDICTION_SWEEP_STEP_LB=0.25
# PREDICTION_SWEEP_TRAVEL_MIN=15
# PREDICTION_SWEEP_DELAY_MS=150

# Training / pre-tournament: synthetic Saturday+Sunday boards (no DynamoDB, no live scrape)
# USE_MOCK_LEADERBOARD=1
# MOCK_TIME_SCALE=20
# 1 real minute = MOCK_TIME_SCALE simulated minutes (default 20)
# MOCK_SIM_START_ISO=2026-04-18T06:30:00
# Simulated Chicago time at process start (defaults: Saturday 6:30am CT this week)
# MOCK_CACHE_MS=1500
# How long to cache a mock snapshot (short = livelier random updates)
# MOCK_RANDOM_SEED=0
# Optional extra RNG seed for repeatable runs
# MOCK_REAL_T0_MS=
# Fix the real-world anchor ms so restarting the server does not reset the sim clock

# Optional ISO dates (YYYY-MM-DD) — if set, payout windows only apply on these two days
# BBB_SATURDAY_DATE=2026-04-18
# BBB_SUNDAY_DATE=2026-04-19

# Cloudflare Tunnel / reverse proxy: public URL of the /fish/ page (injects <base href> so CSS/JS resolve).
# Example: https://abc123.trycloudflare.com/fish
# FISH_PUBLIC_BASE_URL=https://your-host.example.com/fish

# --- Data collection (arrivals + weather + water temp) ---
# Hourly per-weigh-station weather fetches from Open-Meteo. Disable to skip.
# Stations come from server/data/weigh-station-locations.json (no lat/lon env var).
# WEATHER_COLLECT_ENABLED=true
# WEATHER_HOURLY_INTERVAL_MS=3600000
# Once-per-day Ameren surface water temperature scrape. Disable if you don't want the daily HTTP call.
# WATER_TEMP_COLLECT_ENABLED=true

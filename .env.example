# Use 8080 if you prefer http://localhost:8080/fish/ (same server serves API + static).
PORT=3000

# One-command setup + smoke test + dev server (default port 8787; override with FISH_DEV_PORT):
#   npm run fish:dev
#   FISH_DEV_PORT=8080 npm run fish:dev
AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000
TABLE_NAME=bbb_fish_leaderboard
CACHE_TTL_SECONDS=45

# Main A Leaderboard widget (Big Bass Bash). UUID may change per event.
ALEADERBOARD_WIDGET_URL=https://aleaderboard.com/w2/a1161cea-9cb6-4179-9b33-f8baef855ee1

# Optional: fetch Midwest page and pick tallest iframe src if widget URL is empty
MIDWEST_LIVE_PAGE_URL=https://midwestfishtournaments.com/live-leaderboard/

# Heuristic: compare fish to Nth place in current period (Big Bass Bash pays top 45 per period)
PAYOUT_PLACES_HEURISTIC=45

# Training / pre-tournament: synthetic Saturday+Sunday boards (no DynamoDB, no live scrape)
# USE_MOCK_LEADERBOARD=1
# MOCK_TIME_SCALE=20
# 1 real minute = MOCK_TIME_SCALE simulated minutes (default 20)
# MOCK_SIM_START_ISO=2026-04-18T06:30:00
# Simulated Chicago time at process start (defaults: Saturday 6:30am CT this week)
# MOCK_CACHE_MS=1500
# How long to cache a mock snapshot (short = livelier random updates)
# MOCK_RANDOM_SEED=0
# Optional extra RNG seed for repeatable runs
# MOCK_REAL_T0_MS=
# Fix the real-world anchor ms so restarting the server does not reset the sim clock

# Optional ISO dates (YYYY-MM-DD) — if set, payout windows only apply on these two days
# BBB_SATURDAY_DATE=2026-04-18
# BBB_SUNDAY_DATE=2026-04-19
